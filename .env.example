# Nova env (local only; do not commit real values)
#
# Public (safe for client bundle)
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"
VITE_API_URL="https://your-api.example.com"
VITE_STRIPE_PUBLISHABLE_KEY="pk_live_or_test"

# Google OAuth (Desktop app type) — required for integration plugins
NOVA_GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
NOVA_GOOGLE_CLIENT_SECRET="GOCSPX-your-client-secret"

# Prefer keeping signing secrets in .env.signing instead of .env
